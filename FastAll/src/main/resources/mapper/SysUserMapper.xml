<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.ecmo.mapper.SysUserMapper">

    <!-- 统一定义结果映射，让 phone 在查询时自动解密 -->
    <resultMap id="SysUserResult" type="org.example.ecmo.entity.SysUser">
        <id     column="id"              property="id"/>
        <result column="username"        property="username"/>
        <result column="password"        property="password"/>
        <result column="real_name"       property="realName"/>
        <result column="id_card"         property="idCard" typeHandler="org.example.ecmo.handler.EncryptTypeHandler"/>
        <result column="phone"           property="phone" typeHandler="org.example.ecmo.handler.EncryptTypeHandler"/>
        <result column="email"           property="email" typeHandler="org.example.ecmo.handler.EncryptTypeHandler"/>
        <result column="user_type"       property="userType"/>
        <result column="relation_id"     property="relationId"/>
        <result column="avatar"          property="avatar"/>
        <result column="status"          property="status"/>
        <result column="last_login_ip"   property="lastLoginIp"/>
        <result column="last_login_time" property="lastLoginTime"/>
        <result column="created_at"      property="createdAt"/>
        <result column="updated_at"      property="updatedAt"/>
    </resultMap>

<!--    查询所有用户名-->
    <select id="findAllUsernames" resultType="java.lang.String">
        select username from sys_user
    </select>

<!--    根据用户名查询用户信息（使用 resultMap 自动解密 phone）-->
    <select id="findByUsername" resultMap="SysUserResult">
        select * from sys_user where username = #{username}
    </select>

<!--    查看邮箱是否存在-->
    <select id="findByEmail" resultType="java.lang.String">
        select email from sys_user where email = #{email}
    </select>

<!--    插入新用户（phone 字段使用 typeHandler 自动加密）-->
    <insert id="insert" parameterType="org.example.ecmo.entity.SysUser">
        INSERT INTO sys_user (
            username,
            password,
            real_name,
            id_card,
            phone,
            email,
            user_type,
            relation_id,
            avatar,
            status,
            last_login_ip,
            last_login_time,
            created_at,
            updated_at
        ) VALUES (
            #{username},
            #{password},
            #{realName},
            #{idCard, typeHandler=org.example.ecmo.handler.EncryptTypeHandler},
            #{phone, typeHandler=org.example.ecmo.handler.EncryptTypeHandler},
            #{email, typeHandler=org.example.ecmo.handler.EncryptTypeHandler},
            #{userType},
            #{relationId},
            #{avatar},
            #{status},
            #{lastLoginIp},
            #{lastLoginTime},
            NOW(),
            NOW()
        )
    </insert>

</mapper>
